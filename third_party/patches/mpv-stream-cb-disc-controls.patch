+
+    switch (cmd) {
+    case STREAM_CTRL_GET_TIME_LENGTH:
+        cb_cmd = MPV_STREAM_CB_CTRL_GET_TIME_LENGTH;
+        break;
+    case STREAM_CTRL_GET_CURRENT_TIME:
+        cb_cmd = MPV_STREAM_CB_CTRL_GET_CURRENT_TIME;
+        break;
+    case STREAM_CTRL_SEEK_TO_TIME:
+        cb_cmd = MPV_STREAM_CB_CTRL_SEEK_TO_TIME;
+        break;
+    case STREAM_CTRL_GET_NUM_CHAPTERS:
+        cb_cmd = MPV_STREAM_CB_CTRL_GET_NUM_CHAPTERS;
+        break;
+    case STREAM_CTRL_GET_CHAPTER_TIME:
+        cb_cmd = MPV_STREAM_CB_CTRL_GET_CHAPTER_TIME;
+        break;
+    case STREAM_CTRL_GET_LANG: {
+        struct stream_lang_req *req = arg;
+        cb_cmd = MPV_STREAM_CB_CTRL_GET_LANG;
+        lang_req.type = req->type;
+        lang_req.id = req->id;
+        cb_arg = &lang_req;
+        break;
+    }
+    default:
+        return STREAM_UNSUPPORTED;
+    }
+
+    int result = p->info.control_fn(p->info.cookie, cb_cmd, cb_arg);
+    if (result == MPV_STREAM_CB_CONTROL_OK) {
+        if (cmd == STREAM_CTRL_GET_LANG) {
+            struct stream_lang_req *req = arg;
+            snprintf(req->name, sizeof(req->name), "%s", lang_req.name);
+        }
+        if (cmd == STREAM_CTRL_SEEK_TO_TIME)
+            stream_drop_buffers(s);
+        return STREAM_OK;
+    }
+    if (result == MPV_STREAM_CB_CONTROL_ERROR)
+        return STREAM_ERROR;
+    return STREAM_UNSUPPORTED;
+}
