+  private void addMeasuredLiveBatch(List<Danmaku> items, int generation) {
+    if (released || liveGeneration.get() != generation) {
+      return;
+    }
+    for (int i = 0; i < items.size(); i++) {
+      Danmaku danmaku = items.get(i);
+      if (danmaku == null || danmaku.text.isEmpty()) {
+        continue;
+      }
+      if (livePending.size() >= LIVE_PENDING_CAPACITY) {
+        livePending.removeFirst();
+        liveDroppedOverflow++;
+      }
+      livePending.addLast(danmaku);
+      liveOffered++;
+      liveHighWaterMark = Math.max(liveHighWaterMark, livePending.size());
+    }
