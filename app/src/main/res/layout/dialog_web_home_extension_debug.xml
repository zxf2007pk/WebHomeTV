<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_shell_proxy_dialog"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="@string/web_home_extension_debug_title"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reload"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:minWidth="72dp"
            android:text="@string/web_home_extension_preview"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/tabGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabWeb"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/web_home_extension_tab_web"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabConsole"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/web_home_extension_tab_console"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabElements"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/web_home_extension_tab_elements"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabNetwork"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/web_home_extension_tab_network"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabCode"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/web_home_extension_tab_code"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <FrameLayout
        android:id="@+id/pages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/web"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/consoleLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/consoleText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:singleLine="false"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/elementsLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/elementsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:singleLine="false"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/networkLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/networkText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:singleLine="false"
                android:textColor="@color/black" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/codeLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/dialog_outlined_button_stroke"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/codeText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="start|top"
                android:hint="@string/web_home_extension_code_hint"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:singleLine="false"
                android:textColor="@color/black"
                android:textColorHint="#666666" />

        </com.google.android.material.textfield.TextInputLayout>

    </FrameLayout>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inspect"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/web_home_extension_inspect_element"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshConsole"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/web_home_extension_refresh_console"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/save"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/web_home_extension_save_preview"
            android:textColor="@color/dialog_primary_button_text"
            app:backgroundTint="@color/dialog_primary_button_bg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/close"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/dialog_negative"
            android:textColor="@color/dialog_outlined_button_text"
            app:backgroundTint="@color/dialog_outlined_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.appcompat.widget.LinearLayoutCompat>
